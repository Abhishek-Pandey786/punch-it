<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.attendancemanager.controller.ProfileSelectionController"
            stylesheets="@../css/styles.css" prefWidth="800" prefHeight="600">

    <!-- Top Header -->
    <top>
        <VBox styleClass="profile-selection-header" alignment="CENTER" spacing="10">
            <padding>
                <Insets top="40" bottom="30" left="20" right="20"/>
            </padding>
            <Text text="👤 Welcome to Punch IT" styleClass="profile-selection-title"/>
            <Text text="Select your profile to continue" styleClass="profile-selection-subtitle"/>
        </VBox>
    </top>

    <!-- Center - Profile Cards -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="20">
            <padding>
                <Insets top="20" bottom="20" left="40" right="40"/>
            </padding>
            
            <!-- Profiles Grid -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="profile-scroll-pane">
                <VBox fx:id="profilesContainer" spacing="15" alignment="TOP_CENTER">
                    <padding>
                        <Insets top="10" bottom="10" left="10" right="10"/>
                    </padding>
                </VBox>
            </ScrollPane>
            
            <!-- Add New Profile Button -->
            <HBox alignment="CENTER" spacing="15">
                <Button text="➕ Add New Profile" onAction="#handleAddProfile" styleClass="primary-button-large"/>
                <Button text="❌ Exit" onAction="#handleExit" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </center>

    <!-- Bottom Info -->
    <bottom>
        <HBox alignment="CENTER" styleClass="profile-footer">
            <padding>
                <Insets top="15" bottom="15" left="20" right="20"/>
            </padding>
            <Text text="💡 Tip: Each profile maintains separate attendance data" styleClass="profile-hint-text"/>
        </HBox>
    </bottom>
</BorderPane>
